# Copia este archivo a .env y ajusta los valores. NUNCA subas .env al repo.

# --- Base de datos ---
# Formato: postgresql+psycopg://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql+psycopg://canchaya:canchaya@localhost:5432/canchaya

# --- Seguridad / JWT ---
# Genera un secreto fuerte con:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
PROJECT_NAME=CanchaYa
DEBUG=false
